if GetDepend('AIC_HRTIMER_DRV_V10') or GetDepend('AIC_HRTIMER_DRV_V11'):
    if GetDepend('DRIVER_DRV_EN'):
        src += Glob('drv/hrtimer/drv_hrtimer.c')
    if GetDepend('DRIVER_HAL_EN'):
