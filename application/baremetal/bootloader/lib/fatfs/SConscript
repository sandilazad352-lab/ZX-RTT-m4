# RT-Thread building script for component

from building import *

Import('rtconfig')

cwd     = GetCurrentDir()
group = []
if GetDepend('AIC_BOOTLOADER_FATFS_SUPPORT'):
    src     = Glob('*.c')
    CPPPATH = [cwd]
    ASFLAGS = ''

    group = DefineGroup('BLDRV', src, depend = ['AIC_BOOTLOADER'], CPPPATH = CPPPATH, ASFLAGS = ASFLAGS)

Return('group')
