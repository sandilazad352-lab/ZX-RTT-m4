LOCAL_CCFLAGS = ''
# LOCAL_CCFLAGS += ' -O0'

group = DefineGroup('aic_osal', src, depend=[''], CPPPATH=CPPPATH, LOCAL_CCFLAGS=LOCAL_CCFLAGS)

if GetDepend("KERNEL_FREERTOS"):
    group = group + SConscript(os.path.join("drv_freertos", 'SConscript'))

Return('group')
